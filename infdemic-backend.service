[Unit]
Description=Backend INFDEMIC Node.js
After=network.target mysql.service

[Service]
Type=simple
User=joan
WorkingDirectory=/opt/infdemic/backend
ExecStart=/usr/bin/node /opt/infdemic/backend/server.js
Restart=always
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
